<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
  </PropertyGroup>

  <!-- F# compilation order matters — dependencies must come before dependents -->
  <ItemGroup>
    <Compile Include="Domain/Types.fs" />
    <Compile Include="Domain/Dtos.fs" />
    <Compile Include="Telemetry/Otel.fs" />
    <Compile Include="Db/DbFactory.fs" />
    <Compile Include="Db/Queries.fs" />
    <Compile Include="Db/Seed.fs" />
    <Compile Include="Graph/GraphTypes.fs" />
    <Compile Include="Graph/MemoryGraphService.fs" />
    <Compile Include="Logic/Lean/LeanRunner.fs" />
    <Compile Include="Logic/Nd/NdTypes.fs" />
    <Compile Include="Logic/Nd/LeanEmitter.fs" />
    <Compile Include="Routes/HealthRoutes.fs" />
    <Compile Include="Routes/PhilosopherRoutes.fs" />
    <Compile Include="Routes/CatalogRoutes.fs" />
    <Compile Include="Routes/ArgumentRoutes.fs" />
    <Compile Include="Routes/GraphRoutes.fs" />
    <Compile Include="Routes/LeanRoutes.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="FSharp.SystemTextJson" Version="1.4.36" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.4" />
    <PackageReference Include="Npgsql" Version="9.0.3" />
    <PackageReference Include="Npgsql.OpenTelemetry" Version="9.0.3" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.15.2" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.3.2" />
    <PackageReference Include="System.Text.Json" Version="10.0.6" />
  </ItemGroup>

</Project>
