# Dev default: SQLite file — no Postgres install needed.
# The file is created automatically on first db:migrate.
DATABASE_URL=file:./dev.db

# Production: uncomment and set your Postgres URL.
# DATABASE_URL=postgresql://user:password@host:5432/philosophy_explorer

PORT=3001
# Comma-separated allowed CORS origins. Set to your web app URL in production.
ALLOWED_ORIGINS=http://localhost:3000
