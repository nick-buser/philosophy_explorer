{
  "name": "@philosophy-explorer/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":         "tsx watch src/server.ts",
    "build":       "tsc",
    "gen:spec":    "tsx src/scripts/gen-spec.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate":  "drizzle-kit migrate",
    "db:seed":     "tsx src/db/seed.ts",
    "db:studio":   "drizzle-kit studio",
    "test":        "vitest run",
    "test:watch":  "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client":   "^0.14.0",
    "@hono/swagger-ui":  "^0.5.0",
    "@hono/zod-openapi": "^0.18.3",
    "dotenv":            "^16.4.7",
    "drizzle-orm":       "^0.44.0",
    "hono":              "^4.7.4",
    "postgres":          "^3.4.5",
    "zod":               "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "drizzle-kit": "^0.30.4",
    "tsx":         "^4.19.3",
    "typescript":  "^5.8.2",
    "vitest":      "^3.0.8"
  }
}
