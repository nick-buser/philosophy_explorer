{
  "name": "philosophy-explorer",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev:api":     "npm run dev      --workspace=packages/api",
    "dev:web":     "npm run dev      --workspace=packages/web",
    "build:api":   "npm run build    --workspace=packages/api",
    "build:web":   "npm run build    --workspace=packages/web",
    "test:api":    "npm run test     --workspace=packages/api",
    "test:web":    "npm run test     --workspace=packages/web",
    "test":        "npm run test:api && npm run test:web",
    "db:generate": "npm run db:generate --workspace=packages/api",
    "db:migrate":  "npm run db:migrate  --workspace=packages/api",
    "db:seed":     "npm run db:seed     --workspace=packages/api",
    "db:studio":   "npm run db:studio   --workspace=packages/api",
    "gen:spec":    "npm run gen:spec    --workspace=packages/api",
    "gen:types":   "npm run gen:types   --workspace=packages/web"
  }
}
