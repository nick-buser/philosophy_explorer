{
  "name": "philosophy-explorer",
  "version": "0.0.2",
  "private": true,
  "workspaces": [
    "packages/web"
  ],
  "scripts": {
    "dev:api":     "cd packages/api-fsharp/PhilosophyExplorer.Api && DATABASE_URL=file:./dev.db GRAPH_DATA_PATH=$(pwd)/../../../data/graph-data.json dotnet run",
    "dev:web":     "npm run dev      --workspace=packages/web",
    "build:api":   "cd packages/api-fsharp/PhilosophyExplorer.Api && dotnet build -c Release",
    "build:web":   "npm run build    --workspace=packages/web",
    "test:web":    "npm run test     --workspace=packages/web",
    "test:api":    "cd packages/api-fsharp && dotnet test",
    "test":        "npm run test:api; npm run test:web",
    "db:seed":     "cd packages/api-fsharp/PhilosophyExplorer.Api && DATABASE_URL=file:./dev.db SEED_DATA_PATH=$(pwd)/../../../data/seed dotnet run -- --seed",
    "gen:spec":    "bash scripts/gen-spec.sh",
    "gen:types":   "npm run gen:types   --workspace=packages/web"
  }
}
